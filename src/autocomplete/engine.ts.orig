/**
 * Autocomplete Engine with Fuse.js integration
 * Provides fuzzy search with usage pattern learning and persistent storage
 */

import Fuse from "fuse.js";
import * as fs from "node:fs/promises";
import * as path from "node:path";
import type {
  AutocompleteEngine,
  AutocompleteResult,
  AutocompleteConfig,
  UsageHistory,
  UsageStats,
  SearchableItem,
  FuseSearchResult,
  HighlightRange,
} from "./types.js";

export class AutocompleteEngineImpl implements AutocompleteEngine {
  private fuse!: Fuse<SearchableItem>;
  private usageHistory: UsageHistory;
  private config: AutocompleteConfig;
  private items: SearchableItem[] = [];

  constructor(
    items: SearchableItem[] = [],
    config: Partial<AutocompleteConfig> = {}
  ) {
    this.config = {
      maxResults: 10,
      minQueryLength: 1,
      maxResponseTime: 50,
      fuzzyThreshold: 0.4,
      enableUsageLearning: true,
      historyFilePath: path.join(process.cwd(), ".plato", "autocomplete-history.json"),
      ...config,
    };

    this.usageHistory = {
      items: {},
      totalUsages: 0,
      lastUpdated: new Date(),
    };

    this.items = items;
    this.initializeFuse();
    this.loadUsageHistory();
  }

  private initializeFuse(): void {
    const fuseOptions: Fuse.Options<SearchableItem> = {
      keys: [
        { name: "name", weight: 0.7 },
        { name: "aliases", weight: 0.2 },
        { name: "description", weight: 0.1 },
      ],
      threshold: this.config.fuzzyThreshold,
      includeScore: true,
      includeMatches: true,
      minMatchCharLength: 1,
      ignoreLocation: true,
      findAllMatches: false,
      useExtendedSearch: false,
    };

    this.fuse = new Fuse(this.items, fuseOptions);
  }

  public search(query: string, type: "command" | "file" | "mixed"): AutocompleteResult[] {
    const startTime = Date.now();

    if (query.length < this.config.minQueryLength) {
      return [];
    }

    // Filter items by type if not mixed
    const searchItems = type === "mixed"
      ? this.items
      : this.items.filter(item => item.type === type);

    // Update Fuse collection if filtered
    if (type !== "mixed") {
      this.fuse.setCollection(searchItems);
    }

    // Perform fuzzy search
    const fuseResults: Fuse.FuseResult<SearchableItem>[] = this.fuse.search(query, {
      limit: this.config.maxResults * 2 // Get more results for better scoring
    });

    // Convert to AutocompleteResult with enhanced scoring
    const results = fuseResults.map((result): AutocompleteResult => {
      const item = result.item;
      const fuseScore = result.score || 0;
      const usageStats = this.usageHistory.items[item.name];
      const usageCount = usageStats?.count || 0;
      const lastUsed = usageStats?.lastUsed || new Date(0);

      // Calculate enhanced score combining fuzzy + usage + recency
      const finalScore = this.calculateFinalScore(fuseScore, usageCount, lastUsed);

      // Extract highlight ranges from Fuse matches
      const highlight = this.extractHighlightRanges(result.matches || []);

      return {
        item: item.name,
        score: fuseScore,
        type: item.type,
        highlight,
        usageCount,
        lastUsed,
        finalScore,
      };
    });

    // Sort by final score and limit results
    const sortedResults = results
      .sort((a, b) => a.finalScore - b.finalScore)
      .slice(0, this.config.maxResults);

    // Reset Fuse collection if it was filtered
    if (type !== "mixed") {
      this.fuse.setCollection(this.items);
    }

    const elapsed = Date.now() - startTime;
    if (elapsed > this.config.maxResponseTime) {
      console.warn(`Autocomplete search took ${elapsed}ms (target: ${this.config.maxResponseTime}ms)`);
    }

    return sortedResults;
  }

  private calculateFinalScore(fuseScore: number, usageCount: number, lastUsed: Date): number {
    // Fuse score weight (0.6) - lower fuse score is better
    const fuzzyWeight = fuseScore * 0.6;

    // Usage frequency weight (0.25) - logarithmic scale
    const usageWeight = usageCount > 0
      ? (1 - Math.min(1, Math.log10(usageCount + 1) / 2)) * 0.25
      : 0.25;

    // Recency weight (0.15) - last 30 days
    const daysSinceUsed = (Date.now() - lastUsed.getTime()) / (24 * 60 * 60 * 1000);
    const recencyWeight = daysSinceUsed < 30
      ? (1 - Math.max(0, 1 - daysSinceUsed / 30)) * 0.15
      : 0.15;

    return fuzzyWeight + usageWeight + recencyWeight;
  }

  private extractHighlightRanges(matches: Fuse.FuseResultMatch[]): HighlightRange[] {
    const ranges: HighlightRange[] = [];

    for (const match of matches) {
      if (match.key === "name" && match.indices) {
        for (const [start, end] of match.indices) {
          ranges.push({ start, end: end + 1 });
        }
      }
    }

    return ranges.sort((a, b) => a.start - b.start);
  }

  public updateUsageStats(item: string, type: "command" | "file"): void {
    if (!this.config.enableUsageLearning) {
      return;
    }

    const now = new Date();
    const currentStats = this.usageHistory.items[item];

    if (currentStats) {
      currentStats.count++;
      currentStats.lastUsed = now;
    } else {
      this.usageHistory.items[item] = {
        count: 1,
        lastUsed: now,
        type,
      };
    }

    this.usageHistory.totalUsages++;
    this.usageHistory.lastUpdated = now;

    // Save to disk asynchronously
    this.saveUsageHistory().catch(error => {
      console.warn("Failed to save autocomplete usage history:", error);
    });
  }

  public getHistory(): UsageHistory {
    return {
      items: { ...this.usageHistory.items },
      totalUsages: this.usageHistory.totalUsages,
      lastUpdated: this.usageHistory.lastUpdated,
    };
  }

  public clearHistory(): void {
    this.usageHistory = {
      items: {},
      totalUsages: 0,
      lastUpdated: new Date(),
    };
  }

  public updateItems(items: SearchableItem[]): void {
    this.items = items;
    this.initializeFuse();
  }

  private async loadUsageHistory(): Promise<void> {
    try {
      const historyPath = this.config.historyFilePath;
      const historyDir = path.dirname(historyPath);

      // Ensure directory exists
      await fs.mkdir(historyDir, { recursive: true });

      // Load history if file exists
      try {
        const data = await fs.readFile(historyPath, "utf8");
        const parsed = JSON.parse(data);

        // Convert date strings back to Date objects
        this.usageHistory = {
          items: {},
          totalUsages: parsed.totalUsages || 0,
          lastUpdated: new Date(parsed.lastUpdated || Date.now()),
        };

        for (const [itemName, stats] of Object.entries(parsed.items || {})) {
          const statsObj = stats as any;
          this.usageHistory.items[itemName] = {
            count: statsObj.count || 0,
            lastUsed: new Date(statsObj.lastUsed || Date.now()),
            type: statsObj.type || "command",
          };
        }
      } catch (readError: any) {
        if (readError.code !== "ENOENT") {
          console.warn("Failed to load autocomplete history:", readError);
        }
        // File doesn't exist or is corrupted, start fresh
      }
    } catch (error) {
      console.warn("Failed to initialize autocomplete history:", error);
    }
  }

  private async saveUsageHistory(): Promise<void> {
    try {
      const historyPath = this.config.historyFilePath;
      const historyDir = path.dirname(historyPath);

      // Ensure directory exists
      await fs.mkdir(historyDir, { recursive: true });

      // Save history
      await fs.writeFile(historyPath, JSON.stringify(this.usageHistory, null, 2), "utf8");
    } catch (error) {
      throw error;
    }
  }
}

/**
 * Factory function to create a new autocomplete engine
 */
export function createAutocompleteEngine(
  items: SearchableItem[] = [],
  config: Partial<AutocompleteConfig> = {}
): AutocompleteEngine {
  return new AutocompleteEngineImpl(items, config);
}