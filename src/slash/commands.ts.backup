  {
    name: "apply-mode",
    description: "Configure patch apply mode: auto, manual, dry-run, strict, off, or status",
    summary: "Configure patch apply mode: auto, manual, dry-run, strict, off, or status",
    category: "Utility",
    usage: "[auto|manual|dry-run|strict|off|status]",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const { loadConfig, setConfigValue } = await import("../config.js");
        const { status } = await import("../tools/git.js");

        const mode = args[0]?.toLowerCase();
        const validModes = ["auto", "manual", "dry-run", "strict", "off", "status"];

        if (!mode || mode === "status") {
          const config = await loadConfig();
          const currentMode = config.applyMode || "manual";

          let statusOutput = "Patch Apply Mode Configuration:\n";
          statusOutput += "─".repeat(35) + "\n";
          statusOutput += "Current mode: " + currentMode + "\n\n";
          statusOutput += "Available modes:\n";
          statusOutput += "  auto    - Apply patches automatically (Claude Code parity)\n";
          statusOutput += "  manual  - Require confirmation before applying (default)\n";
          statusOutput += "  dry-run - Preview patches only, never apply\n";
          statusOutput += "  strict  - Require clean git state before applying\n";
          statusOutput += "  off     - Disable patch processing entirely\n\n";
          statusOutput += "Usage: /apply-mode [" + validModes.join("|") + "]";

          return { output: statusOutput };
        }

        if (!validModes.includes(mode)) {
          return {
            error: "Invalid apply mode. Use: " + validModes.join(", ")
          };
        }

        // Special validation for strict mode - check git status
        if (mode === "strict") {
          try {
            const gitStatus = await status();
            if (!gitStatus.isClean()) {
              return {
                error: "Cannot enable strict mode: Git working directory is not clean. " +
                      "Commit or stash your changes first."
              };
            }
          } catch (gitError: any) {
            return {
              error: "Cannot enable strict mode: Git repository not found. " +
                    "Initialize a Git repository first with 'git init'."
            };
          }
        }

        await setConfigValue("applyMode", mode);

        let output = "✅ Apply mode set to: " + mode + "\n";

        switch (mode) {
          case "auto":
            output += "  Patches will be applied automatically";
            break;
          case "manual":
            output += "  Patches require confirmation before applying";
            break;
          case "dry-run":
            output += "  Patches will be previewed only, never applied";
            break;
          case "strict":
            output += "  Patches require clean Git state and confirmation";
            break;
          case "off":
            output += "  Patch processing is disabled";
            break;
        }

        return { output };
      } catch (error) {
        return {
          error: "Apply mode configuration failed: " + (error instanceof Error ? error.message : String(error))
        };
      }
    }
  },
  {
    name: "tool-call-preset",
    description: "Configure tool call preset: enable/disable, strict mode, heuristics, custom messages, and per-model overrides",
    summary: "Configure tool call preset: enable/disable, strict mode, heuristics, custom messages, and per-model overrides",
    category: "Configuration",
    usage: "[enable|disable|strict on|off|heuristics on|off|message <text>|override <model> <message>|status]",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const { loadConfig, setConfigValue } = await import("../config.js");

        const subcommand = args[0]?.toLowerCase();

        if (!subcommand || subcommand === "status") {
          const config = await loadConfig();
          const preset = config.toolCallPreset || { enabled: true, strictOnly: true };

          let output = "Tool Call Preset Configuration:\n";
          output += "─".repeat(35) + "\n";
          output += "Enabled: " + (preset.enabled !== false ? "yes" : "no") + "\n";
          output += "Strict mode: " + (preset.strictOnly !== false ? "on" : "off") + "\n";
          output += "Heuristics: " + (preset.allowHeuristics === true ? "on" : "off") + "\n";
          output += "Custom message: " + (preset.messageOverride || "none") + "\n";

          if (preset.overrides && Object.keys(preset.overrides).length > 0) {
            output += "\nPer-model overrides:\n";
            for (const [model, message] of Object.entries(preset.overrides)) {
              output += "  " + model + ": " + message + "\n";
            }
          } else {
            output += "Per-model overrides: none\n";
          }

          output += "\nUsage:\n";
          output += "  enable/disable     - Enable or disable tool call preset\n";
          output += "  strict on/off      - Configure strict JSON-only mode\n";
          output += "  heuristics on/off  - Allow legacy heuristics when not strict\n";
          output += "  message <text>     - Set custom preset message\n";
          output += "  override <model> <message> - Set per-model override\n";
          output += "  status             - Show current configuration";

          return { output };
        }

        const config = await loadConfig();
        let currentPreset = config.toolCallPreset || { enabled: true, strictOnly: true };

        if (subcommand === "enable") {
          currentPreset.enabled = true;
          await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
          return { output: "✅ Tool call preset enabled" };
        }

        if (subcommand === "disable") {
          currentPreset.enabled = false;
          await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
          return { output: "❌ Tool call preset disabled" };
        }

        if (subcommand === "strict") {
          const mode = args[1]?.toLowerCase();
          if (mode === "on") {
            currentPreset.strictOnly = true;
            await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
            return { output: "🔒 Strict mode enabled - only fenced JSON tool calls accepted" };
          } else if (mode === "off") {
            currentPreset.strictOnly = false;
            await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
            return { output: "🔓 Strict mode disabled - legacy heuristics allowed" };
          } else {
            return { error: "Invalid strict mode. Use: strict on|off" };
          }
        }

        if (subcommand === "heuristics") {
          const mode = args[1]?.toLowerCase();
          if (mode === "on") {
            currentPreset.allowHeuristics = true;
            await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
            return { output: "🧠 Heuristics enabled - legacy tool detection allowed" };
          } else if (mode === "off") {
            currentPreset.allowHeuristics = false;
            await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
            return { output: "🚫 Heuristics disabled - strict JSON only" };
          } else {
            return { error: "Invalid heuristics mode. Use: heuristics on|off" };
          }
        }

        if (subcommand === "message") {
          if (args.length < 2) {
            return { error: "Message text required. Usage: message <text>" };
          }
          const message = args.slice(1).join(" ");
          currentPreset.messageOverride = message;
          await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
          return { output: "💬 Custom message set: " + message };
        }

        if (subcommand === "override") {
          if (args.length < 3) {
            return { error: "Model and message required. Usage: override <model> <message>" };
          }
          const model = args[1];
          const message = args.slice(2).join(" ");

          if (!currentPreset.overrides) {
            currentPreset.overrides = {};
          }
          currentPreset.overrides[model] = message;

          await setConfigValue("toolCallPreset", JSON.stringify(currentPreset));
          return { output: "🎯 Override set for " + model + ": " + message };
        }

        return {
          error: "Unknown subcommand. Use: enable|disable|strict|heuristics|message|override|status"
        };

      } catch (error) {
        return {
          error: "Tool call preset configuration failed: " + (error instanceof Error ? error.message : String(error))
        };
      }
    }
  },
  {
    name: "ide",
    description: "Connect to IDE for file awareness and linter warnings",
    summary: "Connect to IDE for file awareness and linter warnings",
    category: "Integration",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        let output = "🔗 IDE Integration Setup\n";
        output += "═".repeat(25) + "\n\n";

        output += "Plato can integrate with your IDE for enhanced development experience:\n\n";

        output += "🎯 Benefits:\n";
        output += "  • Real-time file change awareness\n";
        output += "  • Linter warnings and error reporting\n";
        output += "  • Code completion suggestions\n";
        output += "  • Automatic workspace synchronization\n";
        output += "  • Jump to definition support\n\n";

        output += "📋 Supported IDEs:\n";
        output += "─".repeat(20) + "\n";

        output += "1. VS Code (Recommended)\n";
        output += "   • Install Language Server Protocol extension\n";
        output += "   • Configure workspace settings for Plato\n";
        output += "   • Enable file watchers and auto-save\n\n";

        output += "2. JetBrains IDEs (IntelliJ, WebStorm, PyCharm)\n";
        output += "   • Enable External Tools integration\n";
        output += "   • Configure file system monitoring\n";
        output += "   • Set up LSP client plugin\n\n";

        output += "3. Vim/Neovim\n";
        output += "   • Configure LSP client (coc.nvim, nvim-lsp)\n";
        output += "   • Set up file change notifications\n";
        output += "   • Enable terminal integration\n\n";

        output += "4. Emacs\n";
        output += "   • Use lsp-mode or eglot\n";
        output += "   • Configure file watchers\n";
        output += "   • Set up compilation mode\n\n";

        output += "⚙️ Configuration Steps:\n";
        output += "─".repeat(25) + "\n";

        output += "1. Language Server Setup:\n";
        output += "   • Start Plato LSP server: '/mcp attach lsp http://localhost:9999'\n";
        output += "   • Configure IDE to connect to localhost:9999\n";
        output += "   • Enable workspace folder monitoring\n\n";

        output += "2. File Watcher Configuration:\n";
        output += "   • Watch patterns: **/*.{ts,js,json,md}\n";
        output += "   • Exclude: node_modules, .git, dist, build\n";
        output += "   • Enable auto-save and format on save\n\n";

        output += "3. Workspace Settings (VS Code example):\n";
        output += "   {\n";
        output += "     \"plato.enable\": true,\n";
        output += "     \"plato.lspPort\": 9999,\n";
        output += "     \"files.watcherExclude\": {\n";
        output += "       \"**/.plato/**\": true,\n";
        output += "       \"**/node_modules/**\": true\n";
        output += "     }\n";
        output += "   }\n\n";

        output += "4. Terminal Integration:\n";
        output += "   • Set PLATO_IDE=vscode in environment\n";
        output += "   • Configure shell integration scripts\n";
        output += "   • Enable terminal focus handling\n\n";

        output += "🚀 Quick Start Commands:\n";
        output += "─".repeat(25) + "\n";

        if (process.env.TERM_PROGRAM === "vscode") {
          output += "✅ VS Code detected! Quick setup:\n";
          output += "   1. Install 'Plato Integration' extension\n";
          output += "   2. Restart VS Code\n";
          output += "   3. Run '/ide connect' to establish connection\n\n";
        } else {
          output += "Auto-detection:\n";
          output += "   • TERM_PROGRAM: " + (process.env.TERM_PROGRAM || "unknown") + "\n";
          output += "   • EDITOR: " + (process.env.EDITOR || "unknown") + "\n";
          output += "   • VISUAL: " + (process.env.VISUAL || "unknown") + "\n\n";
        }

        output += "📖 Manual Setup:\n";
        output += "   1. Choose your IDE from the list above\n";
        output += "   2. Follow configuration steps for your IDE\n";
        output += "   3. Test connection with '/ide test'\n";
        output += "   4. Enable features with '/ide enable <feature>'\n\n";

        output += "🔧 Troubleshooting:\n";
        output += "─".repeat(20) + "\n";
        output += "  • Connection issues: Check firewall and port 9999\n";
        output += "  • File sync problems: Verify file watcher permissions\n";
        output += "  • LSP errors: Check IDE LSP client configuration\n";
        output += "  • Performance issues: Exclude large directories\n\n";

        output += "Next steps: Run '/ide connect' to start IDE integration";

        return { output };
      } catch (error) {
        return { error: "IDE integration setup failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
