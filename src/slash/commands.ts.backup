    }
  },
  {
    name: "security-review",
    description: "Review pending changes for safety",
    summary: "Review pending changes for safety",
    category: "Security",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        // Get all messages from session to analyze pending changes
        if (!session?.getMessages) {
          return { error: "No session available to analyze pending changes." };
        }

        const messages = session.getMessages();
        const patches: string[] = [];
        const allContent: string[] = [];

        // Extract patches and collect all assistant content
        for (const message of messages) {
          if (message.role === "assistant" && message.content) {
            const content = message.content;
            allContent.push(content);

            // Extract patches using the same regex as apply command
            const patchRegex = /\*\*\*\s+Begin Patch\s*\*+[\s\S]*?\*\*\*\s+End Patch\s*\**/g;
            const matches = content.match(patchRegex);
            if (matches) {
              patches.push(...matches);
            }
          }
        }

        let output = "🔒 Security Review Report\n";
        output += "═".repeat(30) + "\n\n";

        // Overall risk assessment
        let overallRiskLevel = "low";
        let criticalIssues = 0;
        let highIssues = 0;
        let mediumIssues = 0;
        let recommendations: string[] = [];

        // 1. Analyze patches for sensitive data patterns
        const sensitivePatterns = [
          { pattern: /(?:password|passwd|pwd)\s*[=:]\s*["']?[^"'\s]+/gi, type: "password", severity: "high" },
          { pattern: /(?:api[_-]?key|apikey)\s*[=:]\s*["']?[^"'\s]+/gi, type: "API key", severity: "high" },
          { pattern: /(?:secret[_-]?key|secretkey)\s*[=:]\s*["']?[^"'\s]+/gi, type: "secret key", severity: "high" },
          { pattern: /(?:token|auth[_-]?token)\s*[=:]\s*["']?[^"'\s]+/gi, type: "token", severity: "high" },
          { pattern: /(?:private[_-]?key|privatekey)\s*[=:]\s*["']?[^"'\s]+/gi, type: "private key", severity: "critical" },
          { pattern: /-----BEGIN\s+(?:RSA\s+)?PRIVATE\s+KEY-----/i, type: "private key", severity: "critical" },
          { pattern: /(?:database[_-]?url|db[_-]?url)\s*[=:]\s*["']?[^"'\s]+/gi, type: "database URL", severity: "medium" },
          { pattern: /(?:connection[_-]?string|connectionstring)\s*[=:]\s*["']?[^"'\s]+/gi, type: "connection string", severity: "medium" },
          { pattern: /\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b/g, type: "email address", severity: "low" }
        ];

        const sensitiveDataFound: Array<{type: string, severity: string, context: string}> = [];

        for (const content of allContent) {
          for (const { pattern, type, severity } of sensitivePatterns) {
            const matches = content.match(pattern);
            if (matches) {
              for (const match of matches) {
                // Get some context around the match
                const index = content.indexOf(match);
                const start = Math.max(0, index - 20);
                const end = Math.min(content.length, index + match.length + 20);
                const context = content.substring(start, end).replace(/\n/g, " ");

                sensitiveDataFound.push({ type, severity, context });

                if (severity === "critical") criticalIssues++;
                else if (severity === "high") highIssues++;
                else if (severity === "medium") mediumIssues++;
              }
            }
          }
        }

        // 2. Check for dangerous commands and operations
        const dangerousPatterns = [
          { pattern: /rm\s+-rf\s+[\/~]/g, type: "recursive delete", severity: "critical" },
          { pattern: /sudo\s+rm/g, type: "sudo delete", severity: "high" },
          { pattern: /\beval\s*\(/g, type: "code evaluation", severity: "high" },
          { pattern: /exec\s*\(/g, type: "command execution", severity: "medium" },
          { pattern: /system\s*\(/g, type: "system call", severity: "medium" },
          { pattern: /shell_exec\s*\(/g, type: "shell execution", severity: "high" },
          { pattern: /\$\{[^}]*\}/g, type: "variable substitution", severity: "low" },
          { pattern: /chmod\s+777/g, type: "overly permissive permissions", severity: "medium" },
          { pattern: /--no-verify/g, type: "security bypass", severity: "medium" }
        ];

        const dangerousCommandsFound: Array<{type: string, severity: string, context: string}> = [];

        for (const content of allContent) {
          for (const { pattern, type, severity } of dangerousPatterns) {
            const matches = content.match(pattern);
            if (matches) {
              for (const match of matches) {
                const index = content.indexOf(match);
                const start = Math.max(0, index - 30);
                const end = Math.min(content.length, index + match.length + 30);
                const context = content.substring(start, end).replace(/\n/g, " ");

                dangerousCommandsFound.push({ type, severity, context });

                if (severity === "critical") criticalIssues++;
                else if (severity === "high") highIssues++;
                else if (severity === "medium") mediumIssues++;
              }
            }
          }
        }

        // 3. Analyze patches for file permission changes
        const permissionIssues: Array<{type: string, severity: string, context: string}> = [];

        for (const patch of patches) {
          // Check for file creation with potential security implications
          if (patch.includes("--- /dev/null")) {
            const fileMatch = patch.match(/\+\+\+ b\/(.+)/);
            if (fileMatch) {
              const filename = fileMatch[1];

              // Check for executable files being created
              if (filename.match(/\.(sh|py|pl|rb|exe|bat|cmd)$/)) {
                permissionIssues.push({
                  type: "executable file creation",
                  severity: "medium",
                  context: "Creating executable file: " + filename
                });
                mediumIssues++;
              }

              // Check for config files with potential credentials
              if (filename.match(/\.(conf|config|cfg|ini|env)$/)) {
                permissionIssues.push({
                  type: "configuration file creation",
                  severity: "low",
                  context: "Creating config file: " + filename
                });
              }
            }
          }
        }

        // Determine overall risk level
        if (criticalIssues > 0) {
          overallRiskLevel = "critical";
        } else if (highIssues > 0) {
          overallRiskLevel = "high";
        } else if (mediumIssues > 2) {
          overallRiskLevel = "medium";
        }

        // Generate risk assessment summary
        const riskIcon = overallRiskLevel === "critical" ? "🚨" :
                        overallRiskLevel === "high" ? "⚠️" :
                        overallRiskLevel === "medium" ? "🟡" : "✅";

        output += "📊 Risk Assessment: " + riskIcon + " " + overallRiskLevel.toUpperCase() + " RISK\n";
        output += "─".repeat(20) + "\n";
        output += "Critical issues: " + criticalIssues + "\n";
        output += "High risk issues: " + highIssues + "\n";
        output += "Medium risk issues: " + mediumIssues + "\n";
        output += "Patches analyzed: " + patches.length + "\n\n";

        // Report sensitive data findings
        if (sensitiveDataFound.length > 0) {
          output += "🔑 Sensitive Data Detected:\n";
          output += "─".repeat(25) + "\n";
          for (const finding of sensitiveDataFound) {
            const severityIcon = finding.severity === "critical" ? "🚨" :
                                finding.severity === "high" ? "⚠️" :
                                finding.severity === "medium" ? "🟡" : "ℹ️";
            output += severityIcon + " " + finding.type + " detected\n";
            output += "   Context: ..." + finding.context + "...\n";
          }
          output += "\n";
          recommendations.push("Remove or mask sensitive data before applying changes");
          recommendations.push("Use environment variables or secure vaults for credentials");
        }

        // Report dangerous commands
        if (dangerousCommandsFound.length > 0) {
          output += "⚡ Dangerous Commands Detected:\n";
          output += "─".repeat(28) + "\n";
          for (const finding of dangerousCommandsFound) {
            const severityIcon = finding.severity === "critical" ? "🚨" :
                                finding.severity === "high" ? "⚠️" :
                                finding.severity === "medium" ? "🟡" : "ℹ️";
            output += severityIcon + " " + finding.type + " detected\n";
            output += "   Context: ..." + finding.context + "...\n";
          }
          output += "\n";
          recommendations.push("Review dangerous commands for necessity and safety");
          recommendations.push("Consider using safer alternatives or adding safety checks");
        }

        // Report permission issues
        if (permissionIssues.length > 0) {
          output += "🔐 File Permission Issues:\n";
          output += "─".repeat(25) + "\n";
          for (const finding of permissionIssues) {
            const severityIcon = finding.severity === "medium" ? "🟡" : "ℹ️";
            output += severityIcon + " " + finding.type + "\n";
            output += "   " + finding.context + "\n";
          }
          output += "\n";
          recommendations.push("Review file permissions and executable status");
        }

        // Add patch-specific analysis if patches exist
        if (patches.length > 0) {
          output += "📄 Patch Analysis Summary:\n";
          output += "─".repeat(22) + "\n";
          output += "Total patches found: " + patches.length + "\n";

          let addedLines = 0;
          let deletedLines = 0;
          let modifiedFiles = new Set();

          for (const patch of patches) {
            const lines = patch.split("\n");
            for (const line of lines) {
              if (line.startsWith("+") && !line.startsWith("+++")) addedLines++;
              if (line.startsWith("-") && !line.startsWith("---")) deletedLines++;

              const fileMatch = line.match(/^\+\+\+ b\/(.+)$/);
              if (fileMatch) {
                modifiedFiles.add(fileMatch[1]);
              }
            }
          }

          output += "Files to be modified: " + modifiedFiles.size + "\n";
          output += "Lines to be added: " + addedLines + "\n";
          output += "Lines to be deleted: " + deletedLines + "\n\n";
        }

        // Security recommendations
        if (recommendations.length > 0) {
          output += "💡 Security Recommendations:\n";
          output += "─".repeat(28) + "\n";
          for (let i = 0; i < recommendations.length; i++) {
            output += (i + 1) + ". " + recommendations[i] + "\n";
          }
          output += "\n";
        }

        // Add general security recommendations
        output += "🛡️ General Security Guidelines:\n";
        output += "─".repeat(30) + "\n";
        output += "1. Review all changes before applying patches\n";
        output += "2. Test changes in a safe environment first\n";
        output += "3. Backup important files before modifications\n";
        output += "4. Verify patch integrity and authenticity\n";
        output += "5. Monitor system behavior after changes\n\n";

        // Final warning based on risk level
        if (overallRiskLevel === "critical") {
          output += "🚨 CRITICAL: Do not apply these changes without thorough review and security remediation!\n";
        } else if (overallRiskLevel === "high") {
          output += "⚠️ HIGH RISK: Review and address security issues before applying changes.\n";
        } else if (overallRiskLevel === "medium") {
          output += "🟡 MEDIUM RISK: Consider security implications before proceeding.\n";
        } else {
          output += "✅ LOW RISK: Changes appear relatively safe, but always review before applying.\n";
        }

        return { output };
      } catch (error) {
        return { error: "Security review failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
