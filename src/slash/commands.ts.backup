  {
    name: "output-style",
    description: "Set or switch output style",
    summary: "Set or switch output style",
    category: "UI",
    usage: "[list|set <style>|reset]",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const { getStyleManager } = await import("../styles/manager.js");

        const action = args[0] || "list";
        const styleManager = getStyleManager();
        await styleManager.initialize();

        if (action === "list") {
          const styles = styleManager.listStyles();
          let output = "Available output styles:\n";
          output += "─".repeat(25) + "\n";

          for (const style of styles) {
            const indicator = style.active ? " (active)" : "";
            const type = style.custom ? " [custom]" : " [built-in]";
            output += "  " + style.name + type + indicator + "\n";
            output += "    " + style.description + "\n";
          }

          return { output };
        } else if (action === "set") {
          const styleName = args[1];
          if (!styleName) {
            return { error: "Style name required. Usage: /output-style set <style>" };
          }

          try {
            await styleManager.setStyle(styleName);
            return { output: "Output style set to: " + styleName };
          } catch (error) {
            return { error: "Failed to set style: " + (error instanceof Error ? error.message : String(error)) };
          }
        } else if (action === "reset") {
          await styleManager.setStyle("default");
          return { output: "Output style reset to default" };
        } else {
          return { error: "Unknown action: " + action + ". Use: list, set <style>, or reset" };
        }
      } catch (error) {
        return { error: "Output style command failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
  {
    name: "output-style:new",
    description: "Create a custom output style",
    summary: "Create a custom output style",
    category: "General",
    usage: "<name> [base-style] [options]",
    requiresArgs: true,
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const { getStyleManager } = await import("../styles/manager.js");
        const { BUILTIN_STYLES } = await import("../styles/builtin.js");

        if (args.length === 0) {
          return {
            error: "Style name required. Usage: /output-style:new <name> [options]"
          };
        }

        const styleName = args[0];
        let baseStyle = "default";
        let customizations: any = {
          description: "Custom style: " + styleName
        };

        // Check if second argument is a base style (not starting with --)
        let startIndex = 1;
        if (args.length > 1 && !args[1].startsWith("--")) {
          baseStyle = args[1];
          startIndex = 2;
        }

        // Parse options
        for (let i = startIndex; i < args.length; i++) {
          const arg = args[i];
          const nextArg = args[i + 1];

          if (arg === "--base" && nextArg) {
            baseStyle = nextArg;
            i++; // Skip next arg since we consumed it
          } else if (arg === "--border" && nextArg) {
            if (!customizations.formatting) customizations.formatting = {};
            const borderStyles = ["single", "double", "round", "none"];
            if (borderStyles.includes(nextArg)) {
              customizations.formatting.borderStyle = nextArg;
            } else {
              return { error: "Invalid border style. Use: " + borderStyles.join(", ") };
            }
            i++;
          } else if (arg === "--padding" && nextArg) {
            if (!customizations.formatting) customizations.formatting = {};
            const padding = parseInt(nextArg, 10);
            if (isNaN(padding) || padding < 0) {
              return { error: "Invalid padding value. Must be a non-negative number." };
            }
            customizations.formatting.padding = padding;
            i++;
          } else if (arg === "--icons") {
            if (!customizations.formatting) customizations.formatting = {};
            customizations.formatting.showIcons = true;
          } else if (arg === "--no-icons") {
            if (!customizations.formatting) customizations.formatting = {};
            customizations.formatting.showIcons = false;
          } else if (arg === "--timestamps") {
            if (!customizations.formatting) customizations.formatting = {};
            customizations.formatting.showTimestamps = true;
          } else if (arg === "--no-timestamps") {
            if (!customizations.formatting) customizations.formatting = {};
            customizations.formatting.showTimestamps = false;
          } else if (arg === "--colors" && nextArg) {
            // Parse color theme overrides in format: primary=blue,error=red
            if (!customizations.theme) customizations.theme = {};
            const colorPairs = nextArg.split(",");
            for (const pair of colorPairs) {
              const [colorType, colorValue] = pair.split("=");
              if (colorType && colorValue) {
                customizations.theme[colorType.trim()] = colorValue.trim();
              }
            }
            i++;
          } else if (arg === "--description" && nextArg) {
            customizations.description = nextArg;
            i++;
          } else if (arg.startsWith("--")) {
            return { error: "Unknown option: " + arg + ". Use --base, --border, --padding, --icons, --timestamps, --colors, --description" };
          }
        }

        // Validate base style exists
        const styleManager = getStyleManager();
        await styleManager.initialize();

        const builtinNames = Object.keys(BUILTIN_STYLES);
        const customStyles = styleManager.listStyles().filter(s => s.custom).map(s => s.name);
        const allStyles = [...builtinNames, ...customStyles];

        if (!allStyles.includes(baseStyle)) {
          return {
            error: "Base style '" + baseStyle + "' not found. Available styles: " + allStyles.join(", ")
          };
        }

        // Check if style name already exists
        if (allStyles.includes(styleName)) {
          return {
            error: "Style '" + styleName + "' already exists. Choose a different name or delete the existing style first."
          };
        }

        // Create the custom style
        await styleManager.createCustomStyle(styleName, baseStyle, customizations);

        let output = "Created custom style '" + styleName + "'\n";
        output += "Based on: " + baseStyle + "\n";

        if (customizations.formatting) {
          output += "Customizations:\n";
          if (customizations.formatting.borderStyle !== undefined) {
            output += "  Border: " + customizations.formatting.borderStyle + "\n";
          }
          if (customizations.formatting.padding !== undefined) {
            output += "  Padding: " + customizations.formatting.padding + "\n";
          }
          if (customizations.formatting.showIcons !== undefined) {
            output += "  Icons: " + (customizations.formatting.showIcons ? "enabled" : "disabled") + "\n";
          }
          if (customizations.formatting.showTimestamps !== undefined) {
            output += "  Timestamps: " + (customizations.formatting.showTimestamps ? "enabled" : "disabled") + "\n";
          }
        }

        if (customizations.theme && Object.keys(customizations.theme).length > 0) {
          output += "  Colors: " + Object.entries(customizations.theme).map(([k, v]) => k + "=" + v).join(", ") + "\n";
        }

        output += "\nUse '/output-style " + styleName + "' to activate this style.";

        return { output };
      } catch (error) {
        return {
          error: "Failed to create custom style: " + (error instanceof Error ? error.message : String(error))
        };
      }
    }
  },
