    description: "Fix terminal configuration (Shift+Enter, key bindings)",
    summary: "Fix terminal configuration (Shift+Enter, key bindings)",
    category: "Utility",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        let output = "🖥️ Terminal Configuration Setup\n";
        output += "═".repeat(35) + "\n\n";

        output += "Fix common terminal configuration issues for optimal Plato experience.\n\n";

        output += "🔧 Current Environment:\n";
        output += "─".repeat(25) + "\n";
        output += "  Platform: " + process.platform + " (" + process.arch + ")\n";
        output += "  Terminal: " + (process.env.TERM || "unknown") + "\n";
        output += "  Term Program: " + (process.env.TERM_PROGRAM || "unknown") + "\n";
        output += "  Shell: " + (process.env.SHELL || "unknown") + "\n";
        output += "  Colorterm: " + (process.env.COLORTERM || "not set") + "\n";
        output += "  SSH Connection: " + (process.env.SSH_CONNECTION ? "yes" : "no") + "\n\n";

        output += "🎯 Common Issues & Solutions:\n";
        output += "─".repeat(30) + "\n\n";

        output += "1. Shift+Enter Key Binding Issues:\n";
        output += "   Problem: Shift+Enter sends newline instead of submitting\n";
        output += "   Solutions:\n";
        output += "   • Terminal: Configure key binding for '\u001b[13;2~'\n";
        output += "   • VS Code: Check terminal.integrated.sendKeybindingsToShell\n";
        output += "   • iTerm2: Profiles → Keys → Add '\u001b[13;2~' → Send Text\n";
        output += "   • Windows Terminal: Add key binding in settings.json\n\n";

        output += "2. Raw Mode / Input Handling:\n";
        output += "   Problem: Special keys not working correctly\n";
        output += "   Solutions:\n";
        output += "   • Enable raw mode: export PLATO_RAW_MODE=1\n";
        output += "   • WSL fix: export PLATO_WSL_COMPAT=1\n";
        output += "   • Docker: export PLATO_STATIC_TUI=1\n\n";

        output += "3. Mouse Support Issues:\n";
        output += "   Problem: Mouse interactions not working\n";
        output += "   Solutions:\n";
        output += "   • Enable mouse: /mouse on\n";
        output += "   • Terminal: Check if mouse reporting supported\n";
        output += "   • SSH: Enable X11 forwarding if needed\n\n";

        output += "4. Color/Unicode Display:\n";
        output += "   Problem: Colors or unicode characters broken\n";
        output += "   Solutions:\n";
        output += "   • Set COLORTERM=truecolor\n";
        output += "   • UTF-8: export LC_ALL=en_US.UTF-8\n";
        output += "   • Force colors: export FORCE_COLOR=1\n\n";

        output += "📋 Configuration Files:\n";
        output += "─".repeat(25) + "\n\n";

        if (process.platform === "darwin") {
          output += "macOS Terminal.app:\n";
          output += "  1. Preferences → Profiles → Keyboard\n";
          output += "  2. Add key binding: '\\033[13;2~' for Shift+Enter\n";
          output += "  3. Enable 'Use Option as Meta key'\n\n";

          output += "iTerm2:\n";
          output += "  1. Preferences → Profiles → Keys → Key Mappings\n";
          output += "  2. Add: Shift+Enter → Send Escape Sequence → [13;2~\n";
          output += "  3. Enable mouse reporting\n\n";
        }

        if (process.platform === "win32" || process.env.WSL_DISTRO_NAME) {
          output += "Windows Terminal:\n";
          output += "  Add to settings.json:\n";
          output += "  {\n";
          output += "    \"actions\": [\n";
          output += "      {\n";
          output += "        \"command\": {\n";
          output += "          \"action\": \"sendInput\",\n";
          output += "          \"input\": \"\\u001b[13;2~\"\n";
          output += "        },\n";
          output += "        \"keys\": \"shift+enter\"\n";
          output += "      }\n";
          output += "    ]\n";
          output += "  }\n\n";

          if (process.env.WSL_DISTRO_NAME) {
            output += "WSL Configuration:\n";
            output += "  # Add to ~/.bashrc or ~/.zshrc:\n";
            output += "  export PLATO_WSL_COMPAT=1\n";
            output += "  export PLATO_STATIC_TUI=1\n";
            output += "  export TERM=xterm-256color\n\n";
          }
        }

        if (process.platform === "linux") {
          output += "GNOME Terminal:\n";
          output += "  1. Preferences → Shortcuts\n";
          output += "  2. Disable conflicting shortcuts\n";
          output += "  3. Enable mouse and scroll events\n\n";

          output += "Konsole:\n";
          output += "  1. Settings → Configure Shortcuts\n";
          output += "  2. Configure key bindings\n";
          output += "  3. Enable bidirectional text support\n\n";
        }

        output += "VS Code Integrated Terminal:\n";
        output += "  Add to settings.json:\n";
        output += "  {\n";
        output += "    \"terminal.integrated.sendKeybindingsToShell\": false,\n";
        output += "    \"terminal.integrated.allowMnemonics\": false,\n";
        output += "    \"terminal.integrated.commandsToSkipShell\": [\n";
        output += "      \"workbench.action.terminal.sendSequence\"\n";
        output += "    ]\n";
        output += "  }\n\n";

        output += "🚀 Quick Fix Commands:\n";
        output += "─".repeat(25) + "\n\n";

        const subcommand = args[0]?.toLowerCase();

        if (subcommand === "test") {
          output += "Running terminal capability tests...\n\n";
          output += "✅ Process platform: " + process.platform + "\n";
          output += "✅ TTY support: " + (process.stdout.isTTY ? "yes" : "no") + "\n";
          output += "✅ Color support: " + (process.stdout.hasColors && process.stdout.hasColors() ? "yes" : "basic") + "\n";
          output += "✅ Unicode support: " + (process.env.LC_ALL?.includes("UTF") ? "yes" : "unknown") + "\n\n";
          output += "Run '/keydebug' to test specific key combinations\n\n";
        } else if (subcommand === "fix") {
          output += "Applying automatic fixes...\n\n";
          output += "Environment variables to set:\n";
          if (process.env.WSL_DISTRO_NAME) {
            output += "  export PLATO_WSL_COMPAT=1\n";
            output += "  export PLATO_STATIC_TUI=1\n";
          }
          output += "  export TERM=xterm-256color\n";
          output += "  export COLORTERM=truecolor\n";
          output += "  export LC_ALL=en_US.UTF-8\n\n";
          output += "Add these to your shell profile (~/.bashrc, ~/.zshrc)\n\n";
        } else {
          output += "Available commands:\n";
          output += "  /terminal-setup test    - Test terminal capabilities\n";
          output += "  /terminal-setup fix     - Show environment variable fixes\n";
          output += "  /terminal-setup help    - Show detailed help (this output)\n\n";
        }

        output += "🔍 Diagnostic Commands:\n";
        output += "─".repeat(25) + "\n";
        output += "  /keydebug     - Debug specific key combinations\n";
        output += "  /doctor       - Overall Plato setup diagnosis\n";
        output += "  /debug on     - Enable debug mode for troubleshooting\n";
        output += "  /mouse toggle - Test mouse mode\n\n";

        output += "📚 Reference Documentation:\n";
        output += "─".repeat(30) + "\n";
        output += "  • Terminal escape sequences: https://invisible-island.net/xterm/ctlseqs/ctlseqs.html\n";
        output += "  • ANSI color codes: https://en.wikipedia.org/wiki/ANSI_escape_code\n";
        output += "  • Unicode in terminals: https://unicode.org/charts/\n\n";

        output += "💡 Pro Tips:\n";
        output += "─".repeat(15) + "\n";
        output += "  • Test in multiple terminals to isolate issues\n";
        output += "  • Use '/paste' command for large text input\n";
        output += "  • Configure terminal scrollback buffer size\n";
        output += "  • Enable terminal bells for notifications\n";
        output += "  • Set up terminal profiles for different projects\n\n";

        output += "🔧 Still having issues?\n";
        output += "  Run '/bug' to report terminal-specific problems with full environment details.";

        return { output };
      } catch (error) {
        return { error: "Terminal setup failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
  {
    name: "bug",
    description: "Report bug - opens Plato GitLab issues page",
    summary: "Report bug - opens Plato GitLab issues page",
    category: "Utility",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const fs = await import("fs/promises");
        const path = await import("path");

        // Get repository URL from package.json
        let issuesUrl = "https://git.euraika.net/Bert/plato/-/issues";

        try {
          const packagePath = path.resolve("package.json");
          const packageContent = await fs.readFile(packagePath, "utf8");
          const packageJson = JSON.parse(packageContent);

          if (packageJson.bugs?.url) {
            issuesUrl = packageJson.bugs.url;
          } else if (packageJson.repository?.url) {
            // Convert repository URL to issues URL
            const repoUrl = packageJson.repository.url
              .replace(/\.git$/, "")
              .replace(/^git\+/, "");
            issuesUrl = repoUrl + "/-/issues";
          }
        } catch (error) {
          // Use default URL if package.json cannot be read
        }

        let output = "🐛 Bug Report\n";
        output += "═".repeat(15) + "\n\n";

        output += "To report a bug or issue with Plato:\n\n";

        output += "1. 📋 Gather Information:\n";
        output += "   • What were you trying to do?\n";
        output += "   • What actually happened?\n";
        output += "   • What did you expect to happen?\n";
        output += "   • Can you reproduce the issue?\n\n";

        output += "2. 🔧 System Information:\n";
        output += "   • Operating System: " + process.platform + " " + process.arch + "\n";
        output += "   • Node.js Version: " + process.version + "\n";
        output += "   • Terminal: " + (process.env.TERM || "unknown") + "\n";
        output += "   • Shell: " + (process.env.SHELL || "unknown") + "\n\n";

        // Get current Plato version if possible
        try {
          const packagePath = path.resolve("package.json");
          const packageContent = await fs.readFile(packagePath, "utf8");
          const packageJson = JSON.parse(packageContent);
          output += "   • Plato Version: " + (packageJson.version || "unknown") + "\n\n";
        } catch (error) {
          output += "   • Plato Version: unknown\n\n";
        }

        output += "3. 📝 Include Debug Information:\n";
        output += "   • Run '/debug on' to enable debug mode\n";
        output += "   • Reproduce the issue\n";
        output += "   • Run '/debug logs' to get debug information\n";
        output += "   • Include relevant logs in your report\n\n";

        output += "4. 🌐 Submit Issue:\n";
        output += "   Open: " + issuesUrl + "\n\n";

        output += "💡 Tips for Better Bug Reports:\n";
        output += "   • Use clear, descriptive titles\n";
        output += "   • Include step-by-step reproduction steps\n";
        output += "   • Attach screenshots or terminal output\n";
        output += "   • Mention if the issue is new or recurring\n";
        output += "   • Check existing issues first to avoid duplicates\n\n";

        output += "🔍 Common Issues to Check First:\n";
        output += "   • Run '/doctor' to diagnose setup problems\n";
        output += "   • Check '/terminal-setup' for terminal configuration\n";
        output += "   • Verify '/status' shows proper authentication\n";
        output += "   • Try '/debug status' to check debug configuration\n\n";

        output += "Thank you for helping improve Plato! 🙏";

        // Attempt to open URL automatically if possible
        const shouldTryOpen = args.includes("--open") || args.includes("-o");
        if (shouldTryOpen) {
          try {
            const { spawn } = await import("child_process");

            // Try to determine the platform and open command
            let openCommand: string;
            let openArgs: string[];

            if (process.platform === "darwin") {
              openCommand = "open";
              openArgs = [issuesUrl];
            } else if (process.platform === "win32") {
              openCommand = "start";
              openArgs = ["", issuesUrl];
            } else {
              // Linux and other Unix-like systems
              openCommand = "xdg-open";
              openArgs = [issuesUrl];
            }

            spawn(openCommand, openArgs, { detached: true, stdio: "ignore" });
            output += "\n\n🌐 Opening issues page in your default browser...";

          } catch (openError) {
            // Silently ignore if we can't open the URL
            output += "\n\n(Use --open or -o flag to attempt opening URL automatically)";
          }
        } else {
          output += "\n\n(Use '/bug --open' to try opening the URL automatically)";
        }

        return { output };

      } catch (error) {
        return { error: "Bug report command failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
  {
    name: "debug",
    description: "Manage debug mode settings and diagnostic output",
    summary: "Manage debug mode settings and diagnostic output",
    category: "System",
    usage: "[on|off|level <level>|logs|clear|targets [target...]|status]",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const { loadConfig, setConfigValue } = await import("../config.js");
        const fs = await import("fs/promises");
        const path = await import("path");

        const subcommand = args[0]?.toLowerCase();
        const config = await loadConfig();
        const debugConfig = config.debug || {
          enabled: false,
          level: "minimal",
          targets: [],
          logFile: ".plato/debug.log",
        };

        // Default to status if no subcommand provided
        if (!subcommand || subcommand === "status") {
          let output = "Debug Configuration:\n";
          output += "─".repeat(25) + "\n";
          output += "Enabled: " + (debugConfig.enabled ? "yes" : "no") + "\n";
          output += "Level: " + (debugConfig.level || "minimal") + "\n";
          output += "Log file: " + (debugConfig.logFile || ".plato/debug.log") + "\n";
          output += "Targets: " + (debugConfig.targets && debugConfig.targets.length > 0 ? debugConfig.targets.join(", ") : "none") + "\n\n";

          output += "Available commands:\n";
          output += "  on/off           - Enable or disable debug mode\n";
          output += "  level <level>    - Set debug level (minimal|verbose|full)\n";
          output += "  logs             - Show recent debug logs\n";
          output += "  clear            - Clear debug logs\n";
          output += "  targets [names]  - Set debug targets (space-separated)\n";
          output += "  status           - Show current configuration";

          return { output };
        }

        // Handle enable/disable
        if (subcommand === "on") {
          await setConfigValue("debug.enabled", "true");
          return { output: "✅ Debug mode enabled" };
        }

        if (subcommand === "off") {
          await setConfigValue("debug.enabled", "false");
          return { output: "❌ Debug mode disabled" };
        }

        // Handle debug level
        if (subcommand === "level") {
          const level = args[1]?.toLowerCase();
          if (!level) {
            return { error: "Debug level required. Use: minimal, verbose, or full" };
          }

          if (!["minimal", "verbose", "full"].includes(level)) {
            return { error: "Invalid debug level. Use: minimal, verbose, or full" };
          }

          await setConfigValue("debug.level", level);

          let output = "🔧 Debug level set to: " + level + "\n";
          switch (level) {
            case "minimal":
              output += "  Basic error messages and warnings only";
              break;
            case "verbose":
              output += "  Detailed operation logs and timing information";
              break;
            case "full":
              output += "  Complete diagnostic output with all internal operations";
              break;
          }

          return { output };
        }

        // Handle logs display
        if (subcommand === "logs") {
          const logFile = debugConfig.logFile || ".plato/debug.log";

          try {
            const logPath = path.resolve(logFile);
            const logContent = await fs.readFile(logPath, "utf8");

            if (!logContent.trim()) {
              return { output: "Debug log is empty" };
            }

            // Show last 50 lines
            const lines = logContent.trim().split("\n");
            const recentLines = lines.slice(-50);

            let output = "Recent Debug Logs (" + recentLines.length + " of " + lines.length + " lines):\n";
            output += "─".repeat(40) + "\n";
            output += recentLines.join("\n");

            return { output };
          } catch (error: any) {
            if (error.code === "ENOENT") {
              return { output: "No debug log file found at: " + logFile };
            }
            return { error: "Failed to read debug logs: " + error.message };
          }
        }

        // Handle log clearing
        if (subcommand === "clear") {
          const logFile = debugConfig.logFile || ".plato/debug.log";

          try {
            const logPath = path.resolve(logFile);
            await fs.writeFile(logPath, "", "utf8");
            return { output: "🗑️ Debug logs cleared" };
          } catch (error: any) {
            return { error: "Failed to clear debug logs: " + error.message };
          }
        }

        // Handle debug targets
        if (subcommand === "targets") {
          const targets = args.slice(1);

          if (targets.length === 0) {
            const currentTargets = debugConfig.targets || [];
            let output = "Current debug targets:\n";
            if (currentTargets.length === 0) {
              output += "  None - debugging all components";
            } else {
              output += "  " + currentTargets.join(", ");
            }
            output += "\n\nCommon targets:\n";
            output += "  mcp, tools, runtime, tui, keyboard, providers, auth, config";
            return { output };
          }

          // Validate targets
          const validTargets = ["mcp", "tools", "runtime", "tui", "keyboard", "providers", "auth", "config", "permissions", "context", "memory"];
          const invalidTargets = targets.filter(t => !validTargets.includes(t.toLowerCase()));

          if (invalidTargets.length > 0) {
            return { error: "Invalid targets: " + invalidTargets.join(", ") + ". Valid targets: " + validTargets.join(", ") };
          }

          const newDebugConfig = {
            ...debugConfig,
            targets: targets.map(t => t.toLowerCase()),
          };

          await setConfigValue("debug", JSON.stringify(newDebugConfig));

          return { output: "🎯 Debug targets set to: " + targets.join(", ") };
        }

        return { error: "Unknown debug command. Use: on, off, level, logs, clear, targets, or status" };

      } catch (error) {
        return { error: "Debug command failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
];

export const SLASH_MAP = new Map(
  SLASH_COMMANDS.map((c) => [c.name, c] as const),
);


// Export for router
export const slashCommands = SLASH_COMMANDS;

// Helper functions for MCP command implementation
async function handleMcpStatus(): Promise<{ output: string }> {
  try {
    const { listServers, health } = await import("../integrations/mcp.js");

    const servers = await listServers();
    const healthResults = await health();

    let output = "MCP System Status\n";
    output += "═".repeat(20) + "\n";
    output += "Total servers: " + servers.length + "\n";

    if (servers.length === 0) {
      output += "No MCP servers attached\n\n";
      output += "Usage: /mcp attach <name> <url>\n";
      output += "Example: /mcp attach local http://localhost:8719";
      return { output };
    }

    output += "\nServer Health:\n";
    output += "─".repeat(15) + "\n";

    for (const result of healthResults) {
      const statusIcon = result.ok ? "✅" : "❌";
      const statusText = result.ok ? "Healthy" : "Unreachable";
      const statusCode = result.status ? " (" + result.status + ")" : "";
      output += "  " + statusIcon + " " + result.id + ": " + statusText + statusCode + "\n";
    }

    return { output };
  } catch (error) {
    return { output: "Failed to get MCP status: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleMcpList(): Promise<{ output: string }> {
  try {
    const { listServers, health } = await import("../integrations/mcp.js");

    const servers = await listServers();
    const healthResults = await health();
    const healthMap = new Map(healthResults.map(h => [h.id, h]));

    let output = "Attached MCP Servers:\n";
    output += "─".repeat(25) + "\n";

    if (servers.length === 0) {
      output += "No servers attached\n\n";
      output += "To attach a server: /mcp attach <name> <url>";
      return { output };
    }

    for (const server of servers) {
      const healthInfo = healthMap.get(server.id);
      const statusIcon = healthInfo?.ok ? "🟢" : "🔴";
      const statusText = healthInfo?.ok ? "Online" : "Offline";

      output += "  " + statusIcon + " " + server.id + "\n";
      output += "    URL: " + server.url + "\n";
      output += "    Status: " + statusText + "\n";
      if (healthInfo?.status) {
        output += "    Last response: " + healthInfo.status + "\n";
      }
      output += "\n";
    }

    return { output };
  } catch (error) {
    return { output: "Failed to list MCP servers: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleMcpAttach(args: string[]): Promise<{ output?: string; error?: string }> {
  if (args.length < 2) {
    return { error: "Usage: /mcp attach <name> <url>" };
  }

  const [name, url] = args;

  // Validate URL format
  try {
    new URL(url);
  } catch {
    return { error: "Invalid URL format: " + url };
  }

  // Check if URL is reachable
  try {
    const response = await fetch(url + "/health", {
      method: "HEAD",
      signal: AbortSignal.timeout(10000)
    });

    if (!response.ok && response.status !== 404) {
      return { error: "Server health check failed: " + response.status + " " + response.statusText };
    }
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    return { error: "Failed to connect to MCP server: " + message };
  }

  try {
    const { attachServer } = await import("../integrations/mcp.js");
    await attachServer(name, url);

    return { output: "Successfully attached MCP server '" + name + "' at " + url };
  } catch (error) {
    return { error: "Failed to attach server: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleMcpDetach(args: string[]): Promise<{ output?: string; error?: string }> {
  if (args.length < 1) {
    return { error: "Usage: /mcp detach <name>" };
  }

  const name = args[0];

  try {
    const { detachServer } = await import("../integrations/mcp.js");
    await detachServer(name);

    return { output: "Successfully detached MCP server '" + name + "'" };
  } catch (error) {
    return { error: "Failed to detach server: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleMcpTools(args: string[]): Promise<{ output: string }> {
  try {
    const { listTools } = await import("../integrations/mcp.js");

    const serverId = args[0];
    const toolsByServer = await listTools(serverId);

    let output = "Available MCP Tools:\n";
    output += "─".repeat(25) + "\n";

    if (toolsByServer.length === 0) {
      output += "No tools available\n";
      if (serverId) {
        output += "Server '" + serverId + "' not found or has no tools";
      } else {
        output += "No MCP servers attached or no tools exposed";
      }
      return { output };
    }

    for (const { server, tools } of toolsByServer) {
      output += "\n📦 Server: " + server + "\n";

      if (tools.length === 0) {
        output += "  No tools available\n";
        continue;
      }

      for (const tool of tools) {
        output += "  🔧 " + tool.name + "\n";
        if (tool.description) {
          output += "    " + tool.description + "\n";
        }
        if (tool.input_schema?.properties) {
          const params = Object.keys(tool.input_schema.properties);
          if (params.length > 0) {
            output += "    Parameters: " + params.join(", ") + "\n";
          }
        }
      }
    }

    return { output };
  } catch (error) {
    return { output: "Failed to list tools: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleMcpTest(args: string[]): Promise<{ output?: string; error?: string }> {
  if (args.length < 1) {
    return { error: "Usage: /mcp test <name>" };
  }

  const name = args[0];

  try {
    const { health, listServers } = await import("../integrations/mcp.js");

    // Check if server exists
    const servers = await listServers();
    const server = servers.find(s => s.id === name);

    if (!server) {
      return { error: "Server '" + name + "' not found. Use /mcp list to see attached servers." };
    }

    // Test connectivity
    const healthResults = await health(name);
    const result = healthResults[0];

    let output = "MCP Server Test: " + name + "\n";
    output += "─".repeat(20 + name.length) + "\n";
    output += "URL: " + server.url + "\n";

    if (result.ok) {
      output += "Status: ✅ Online\n";
      output += "Response code: " + (result.status || "200") + "\n";

      // Test tools endpoint
      try {
        const { listTools } = await import("../integrations/mcp.js");
        const toolsByServer = await listTools(name);
        const tools = toolsByServer.find(ts => ts.server === name)?.tools || [];

        output += "Tools available: " + tools.length + "\n";
        if (tools.length > 0) {
          output += "Sample tools: " + tools.slice(0, 3).map(t => t.name).join(", ");
          if (tools.length > 3) {
            output += " (+" + (tools.length - 3) + " more)";
          }
          output += "\n";
        }
      } catch (toolError) {
        output += "Tools endpoint: ⚠️ Error accessing tools\n";
      }

      output += "\n✅ Connection test passed";
    } else {
      output += "Status: ❌ Offline\n";
      output += "Error: Connection failed\n";
      output += "\n❌ Connection test failed";
    }

    return { output };
  } catch (error) {
    return { error: "Test failed: " + (error instanceof Error ? error.message : String(error)) };
  }
}

// Helper functions for context command implementation
async function handleContextStatus(session: any): Promise<{ output: string }> {
  try {
    let output = "Context Status\n";
    output += "═".repeat(15) + "\n";

    // Get conversation metrics
    const stats = session?.getStats ? session.getStats() : { messageCount: 0, inputTokens: 0, outputTokens: 0 };

    output += "📊 Conversation Metrics:\n";
    output += "  Messages: " + (stats.messageCount || stats.messages || 0) + "\n";
    output += "  Input tokens: " + (stats.inputTokens || stats.tokens?.input || 0) + "\n";
    output += "  Output tokens: " + (stats.outputTokens || stats.tokens?.output || 0) + "\n";
    output += "  Total tokens: " + ((stats.inputTokens || 0) + (stats.outputTokens || 0)) + "\n\n";

    // Token usage breakdown
    const totalTokens = (stats.inputTokens || 0) + (stats.outputTokens || 0);
    const contextLimit = 128000; // Default context limit for most models
    const usagePercent = Math.round((totalTokens / contextLimit) * 100);

    output += "🎯 Context Usage:\n";
    output += "  Current: " + totalTokens + " / " + contextLimit + " tokens (" + usagePercent + "%)\n";

    // Create ASCII progress bar
    const barLength = 20;
    const filledBars = Math.round((usagePercent / 100) * barLength);
    const emptyBars = barLength - filledBars;
    const progressBar = "█".repeat(filledBars) + "░".repeat(emptyBars);

    let barColor = "";
    if (usagePercent < 50) barColor = "🟢";
    else if (usagePercent < 75) barColor = "🟡";
    else if (usagePercent < 90) barColor = "🟠";
    else barColor = "🔴";

    output += "  Progress: " + barColor + " [" + progressBar + "] " + usagePercent + "%\n\n";

    // Memory pressure warnings
    if (usagePercent > 90) {
      output += "⚠️ HIGH MEMORY PRESSURE\n";
      output += "  Context is nearly full. Consider:\n";
      output += "  • /context compact - Compress old context\n";
      output += "  • /context clear - Clear conversation history\n";
      output += "  • /context export <file> - Save before clearing\n\n";
    } else if (usagePercent > 75) {
      output += "🟡 MODERATE MEMORY USAGE\n";
      output += "  Context is getting full. Monitor usage.\n\n";
    } else {
      output += "✅ OPTIMAL MEMORY USAGE\n";
      output += "  Context usage is within healthy limits.\n\n";
    }

    // Context breakdown
    const messages = session?.getHistory ? session.getHistory() : [];
    const userMessages = messages.filter((m: any) => m.role === "user").length;
    const assistantMessages = messages.filter((m: any) => m.role === "assistant").length;
    const systemMessages = messages.filter((m: any) => m.role === "system").length;

    output += "📝 Message Breakdown:\n";
    output += "  User messages: " + userMessages + "\n";
    output += "  Assistant messages: " + assistantMessages + "\n";
    output += "  System messages: " + systemMessages + "\n\n";

    output += "🛠️ Available Commands:\n";
    output += "  /context clear        - Clear conversation context\n";
    output += "  /context export <file> - Export context to file\n";
    output += "  /context compact      - Compress old context\n";
    output += "  /context status       - Show this status (default)";

    return { output };
  } catch (error) {
    return { output: "Failed to get context status: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleContextClear(session: any): Promise<{ output?: string; error?: string; requiresConfirmation?: boolean }> {
  try {
    if (!session?.clearHistory) {
      return { error: "No session available or session does not support clearing history." };
    }

    const stats = session.getStats ? session.getStats() : { messageCount: 0 };
    const messageCount = stats.messageCount || stats.messages || 0;

    if (messageCount === 0) {
      return { output: "Context is already empty." };
    }

    // Clear the conversation history
    session.clearHistory();

    // Reset token metrics if available
    if (session.resetTokenMetrics) {
      session.resetTokenMetrics();
    }

    let output = "🗑️ Context Cleared\n";
    output += "─".repeat(20) + "\n";
    output += "Removed " + messageCount + " messages from conversation history.\n";
    output += "Token counters reset.\n\n";
    output += "✅ Context is now empty and ready for new conversation.";

    return { output };
  } catch (error) {
    return { error: "Failed to clear context: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleContextExport(args: string[], session: any): Promise<{ output?: string; error?: string }> {
  if (args.length < 1) {
    return { error: "Usage: /context export <filename>" };
  }

  const filename = args[0];

  try {
    const fs = await import("fs/promises");
    const path = await import("path");

    if (!session?.getHistory) {
      return { error: "No session available or session does not support exporting." };
    }

    const messages = session.getHistory();
    if (messages.length === 0) {
      return { error: "No conversation history to export." };
    }

    // Create export data
    const exportData = {
      exportedAt: new Date().toISOString(),
      messageCount: messages.length,
      stats: session.getStats ? session.getStats() : {},
      messages: messages
    };

    // Determine file format based on extension
    const ext = path.extname(filename).toLowerCase();
    let content: string;

    if (ext === ".json") {
      content = JSON.stringify(exportData, null, 2);
    } else if (ext === ".md" || ext === ".txt" || ext === "") {
      // Plain text/markdown format
      content = "# Conversation Export\n\n";
      content += "Exported: " + exportData.exportedAt + "\n";
      content += "Messages: " + exportData.messageCount + "\n\n";
      content += "---\n\n";

      for (const message of messages) {
        content += "## " + message.role.charAt(0).toUpperCase() + message.role.slice(1) + "\n\n";
        content += message.content + "\n\n";
      }
    } else {
      return { error: "Unsupported file format. Use .json, .md, or .txt" };
    }

    // Write to file
    const fullPath = path.resolve(filename);
    await fs.writeFile(fullPath, content, "utf8");

    let output = "📁 Context Exported\n";
    output += "─".repeat(20) + "\n";
    output += "File: " + fullPath + "\n";
    output += "Format: " + (ext || "text") + "\n";
    output += "Messages: " + messages.length + "\n";
    output += "Size: " + Math.round(content.length / 1024) + " KB\n\n";
    output += "✅ Export completed successfully.";

    return { output };
  } catch (error) {
    return { error: "Failed to export context: " + (error instanceof Error ? error.message : String(error)) };
  }
}

async function handleContextCompact(session: any): Promise<{ output?: string; error?: string }> {
  try {
    if (!session?.compactHistoryWithFocus) {
      return { error: "Session does not support context compaction." };
    }

    const beforeStats = session.getStats ? session.getStats() : { messageCount: 0 };
    const beforeCount = beforeStats.messageCount || beforeStats.messages || 0;

    if (beforeCount === 0) {
      return { output: "No conversation history to compact." };
    }

    // Perform compaction
    const result = await session.compactHistoryWithFocus();
    const originalLength = result.originalLength || beforeCount;
    const newLength = result.newLength || beforeCount;
    const saved = originalLength - newLength;
    const savedPercent = originalLength > 0 ? Math.round((saved / originalLength) * 100) : 0;

    let output = "🗜️ Context Compacted\n";
    output += "─".repeat(20) + "\n";
    output += "Original messages: " + originalLength + "\n";
    output += "Compacted to: " + newLength + "\n";
    output += "Removed: " + saved + " messages (" + savedPercent + "%)\n\n";

    if (saved > 0) {
      output += "✅ Context successfully compacted to preserve memory.";
    } else {
      output += "ℹ️ No compaction needed - context is already optimized.";
    }

    return { output };
  } catch (error) {
    return { error: "Failed to compact context: " + (error instanceof Error ? error.message : String(error)) };
  }
}