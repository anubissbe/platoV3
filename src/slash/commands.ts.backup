  {
    name: "privacy-settings",
    description: "View and update privacy settings",
    summary: "View and update privacy settings",
    category: "Security",
    usage: "[redact on|off] [prompt_on_large_payloads on|off] [max_payload_mb <size>] [status]",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const { loadConfig, setConfigValue } = await import("../config.js");

        const config = await loadConfig();
        const privacyConfig = config.privacy || {};

        // If no arguments or status requested, show current settings
        if (args.length === 0 || args[0] === "status") {
          let output = "Privacy Settings Configuration:\n";
          output += "─".repeat(35) + "\n";
          output += "Redact sensitive data: " + (privacyConfig.redact ? "enabled" : "disabled") + "\n";
          output += "Prompt on large payloads: " + (privacyConfig.prompt_on_large_payloads ? "enabled" : "disabled") + "\n";
          output += "Max payload size: " + (privacyConfig.max_payload_mb || "unlimited") + " MB\n";
          output += "Skip all prompts: " + (privacyConfig.skip_all_prompts ? "enabled" : "disabled") + "\n";
          output += "Dangerous mode: " + (privacyConfig.dangerous_mode ? "enabled" : "disabled") + "\n\n";

          output += "Available commands:\n";
          output += "  redact on|off              - Enable/disable sensitive data redaction\n";
          output += "  prompt_on_large_payloads on|off - Enable/disable large payload prompts\n";
          output += "  max_payload_mb <size>      - Set maximum payload size in MB\n";
          output += "  status                     - Show current configuration";

          return { output };
        }

        const setting = args[0];
        const value = args[1];

        if (setting === "redact") {
          if (value === "on") {
            await setConfigValue("privacy.redact", "true");
            return { output: "✅ Sensitive data redaction enabled" };
          } else if (value === "off") {
            await setConfigValue("privacy.redact", "false");
            return { output: "❌ Sensitive data redaction disabled" };
          } else {
            return { error: "Invalid value for redact. Use: on|off" };
          }
        }

        if (setting === "prompt_on_large_payloads") {
          if (value === "on") {
            await setConfigValue("privacy.prompt_on_large_payloads", "true");
            return { output: "✅ Large payload prompts enabled" };
          } else if (value === "off") {
            await setConfigValue("privacy.prompt_on_large_payloads", "false");
            return { output: "❌ Large payload prompts disabled" };
          } else {
            return { error: "Invalid value for prompt_on_large_payloads. Use: on|off" };
          }
        }

        if (setting === "max_payload_mb") {
          const sizeStr = value;
          if (!sizeStr) {
            return { error: "Size value required for max_payload_mb" };
          }

          const size = parseFloat(sizeStr);
          if (isNaN(size) || size <= 0) {
            return { error: "Invalid size value. Must be a positive number" };
          }

          await setConfigValue("privacy.max_payload_mb", sizeStr);
          return { output: "📏 Maximum payload size set to " + size + " MB" };
        }

        return { error: "Unknown privacy setting. Use: redact, prompt_on_large_payloads, max_payload_mb, or status" };

      } catch (error) {
        return { error: "Privacy settings failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
  {
    name: "release-notes",
    description: "Show Plato release notes",
    summary: "Show Plato release notes",
    category: "Utility",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const fs = await import("fs/promises");
        const path = await import("path");

        let output = "Plato Release Notes\n";
        output += "═".repeat(25) + "\n\n";

        // Try to read package.json for current version
        try {
          const packagePath = path.resolve("package.json");
          const packageContent = await fs.readFile(packagePath, "utf8");
          const packageJson = JSON.parse(packageContent);

          output += "Current Version: " + (packageJson.version || "unknown") + "\n";
          output += "Repository: " + (packageJson.repository?.url || "N/A") + "\n\n";
        } catch (pkgError) {
          output += "Current Version: 0.1.0 (default)\n\n";
        }

        // Try to read CHANGELOG.md or similar files
        const changelogPaths = ["CHANGELOG.md", "CHANGES.md", "RELEASES.md", "HISTORY.md"];
        let changelogFound = false;

        for (const changelogPath of changelogPaths) {
          try {
            const fullPath = path.resolve(changelogPath);
            const changelogContent = await fs.readFile(fullPath, "utf8");

            output += "Release History:\n";
            output += "─".repeat(20) + "\n";

            // Show first 50 lines or 2000 characters, whichever is less
            const lines = changelogContent.split("\n").slice(0, 50);
            const limitedContent = lines.join("\n");
            const truncatedContent = limitedContent.length > 2000 ?
              limitedContent.substring(0, 2000) + "...\n\n[Content truncated - see " + changelogPath + " for full history]" :
              limitedContent;

            output += truncatedContent;
            changelogFound = true;
            break;
          } catch (error) {
            // Continue to next changelog file
          }
        }

        if (!changelogFound) {
          output += "Version 0.1.0 - Initial Development Release\n";
          output += "─".repeat(40) + "\n";
          output += "Core Features:\n";
          output += "• Terminal UI with React + Ink framework\n";
          output += "• GitLab Duo and GitHub Copilot integration\n";
          output += "• MCP (Model Context Protocol) server support\n";
          output += "• Tool-call bridge system for extensions\n";
          output += "• Patch engine with Git integration\n";
          output += "• Session persistence and memory management\n";
          output += "• Comprehensive slash command system\n";
          output += "• Security review and permissions system\n";
          output += "• Multiple output styles and customization\n";
          output += "• Cross-platform terminal compatibility\n\n";

          output += "Development Status:\n";
          output += "• 119 test files with comprehensive coverage\n";
          output += "• TypeScript with strict type checking\n";
          output += "• ESLint and Prettier code formatting\n";
          output += "• Jest testing framework\n";
          output += "• CI/CD integration ready\n\n";

          output += "Recent Improvements:\n";
          output += "• Enhanced keyboard handling for WSL compatibility\n";
          output += "• Improved tool-call preset system\n";
          output += "• Advanced debug configuration\n";
          output += "• Better error recovery and graceful degradation\n";
          output += "• Privacy settings management\n\n";
        }

        output += "For the latest updates and issues:\n";
        output += "Repository: https://git.euraika.net/Bert/plato\n";
        output += "Issues: https://git.euraika.net/Bert/plato/-/issues\n";
        output += "Documentation: See README.md and src/docs/\n";

        return { output };

      } catch (error) {
        return { error: "Failed to show release notes: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
