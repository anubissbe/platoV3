  {
    name: "context",
    description: "Manage context and visualize token usage",
    summary: "Manage context and visualize token usage",
    category: "Session",
    usage: "[clear|export <file>|compact|status]",
    execute: async (args: string[], session: any, provider?: any) => {
      try {
        const subcommand = args[0]?.toLowerCase();

        if (!subcommand || subcommand === "status") {
          return await handleContextStatus(session);
        }

        switch (subcommand) {
          case "clear":
            return await handleContextClear(session);
          case "export":
            return await handleContextExport(args.slice(1), session);
          case "compact":
            return await handleContextCompact(session);
          default:
            return { error: "Unknown context command. Use: status, clear, export <file>, compact" };
        }
      } catch (error) {
        return { error: "Context command failed: " + (error instanceof Error ? error.message : String(error)) };
      }
    }
  },
