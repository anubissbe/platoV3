{
  "name": "@plato/monitoring-dashboard",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for Plato TUI Enterprise",
  "main": "src/index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "npm start",
    "serve": "serve -s build",
    "build:prod": "npm run build && npm run optimize",
    "optimize": "node scripts/optimize-build.js",
    "analyze": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js",
    "docker:build": "docker build -t plato-monitoring-dashboard .",
    "docker:run": "docker run -p 3001:80 plato-monitoring-dashboard",
    "k8s:deploy": "kubectl apply -f k8s/",
    "monitoring:setup": "node scripts/setup-monitoring.js"
  },
  "keywords": [
    "monitoring",
    "dashboard",
    "observability",
    "metrics",
    "plato-tui"
  ],
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "@mui/material": "^5.11.0",
    "@mui/icons-material": "^5.11.0",
    "@mui/x-charts": "^6.0.0",
    "@mui/x-data-grid": "^6.0.0",
    "@emotion/react": "^11.10.0",
    "@emotion/styled": "^11.10.0",
    "recharts": "^2.5.0",
    "socket.io-client": "^4.6.0",
    "axios": "^1.3.0",
    "date-fns": "^2.29.0",
    "lodash": "^4.17.21",
    "@tanstack/react-query": "^4.0.5",
    "react-hook-form": "^7.43.0",
    "react-hot-toast": "^2.4.0",
    "framer-motion": "^10.0.0",
    "d3": "^7.8.0",
    "victory": "^36.6.0",
    "nivo": "^0.84.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/lodash": "^4.14.0",
    "@types/d3": "^7.4.0",
    "typescript": "^4.9.0",
    "serve": "^14.2.0",
    "webpack-bundle-analyzer": "^4.8.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}