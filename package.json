{
  "name": "plato-copilot-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Terminal coding assistant CLI compatible with Claude Code UX, backed by GitLab Duo and Copilot APIs.",
  "repository": {
    "type": "git",
    "url": "https://git.euraika.net/Bert/plato.git"
  },
  "homepage": "https://git.euraika.net/Bert/plato",
  "bugs": {
    "url": "https://git.euraika.net/Bert/plato/-/issues"
  },
  "bin": {
    "plato": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "build:check-tests": "tsc -p tsconfig.tests.json",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "fmt": "prettier -w .",
    "claude:capabilities": "tsx scripts/print-claude-capabilities.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:components": "jest --testMatch='**/__tests__/components/**/*.test.tsx'",
    "test:e2e": "jest e2e",
    "test:all": "npm run test:organized && npm run test:components && npm run test:e2e",
    "docker:build": "docker build -f Dockerfile.mcp -t plato-mcp:latest .",
    "docker:run": "docker run --rm -it -p 8719:3000 -v \"$PWD:/workspace\" plato-mcp:latest",
    "mcp:serve": "node scripts/mcp-tui-server.mjs",
    "test:organized": "npm run test:main && npm run test:tools && npm run test:integration",
    "test:main": "jest --config=jest.config.cjs",
    "test:main:watch": "jest --config=jest.config.cjs --watch",
    "test:main:coverage": "jest --config=jest.config.cjs --coverage",
    "test:tools": "jest --config=jest.config.tools.cjs",
    "test:tools:watch": "jest --config=jest.config.tools.cjs --watch",
    "test:tools:coverage": "jest --config=jest.config.tools.cjs --coverage",
    "test:reliable": "jest --config=jest.config.reliable.cjs",
    "test:reliable-watch": "jest --config=jest.config.reliable.cjs --watch",
    "test:master": "jest --config=jest.config.master.cjs",
    "test:unit": "jest --testPathPattern='__tests__/unit'",
    "test:integration": "jest --config=jest.config.integration.cjs",
    "test:commands": "jest commands",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:fast": "jest --config=jest.config.performance.cjs",
    "test:perf": "jest --config=jest.config.performance.cjs --maxWorkers=75%",
    "test:quick": "jest --config=jest.config.performance.cjs --bail --findRelatedTests",
    "test:fast-watch": "jest --config=jest.config.performance.cjs --watch",
    "test:integration-only": "jest --config=jest.config.integration.cjs",
    "test:performance": "npm run test:fast && npm run test:integration-only",
    "test:parallel": "jest --config=jest.config.performance.cjs --maxWorkers=75%",
    "test:with-retry": "npx tsx scripts/test-with-retry.ts",
    "test:retry-reliable": "npx tsx scripts/test-with-retry.ts npm run test:reliable",
    "test:comprehensive": "npm run test:reliable && npm run test:integration-only",
    "test:coverage:comprehensive": "jest --config=jest.config.coverage.cjs",
    "test:coverage:watch": "jest --config=jest.config.coverage.cjs --watch",
    "test:coverage:detailed": "jest --config=jest.config.coverage.cjs --collectCoverageFrom='src/**/*.{ts,tsx}' --coverageReporters=html --coverageReporters=text-summary",
    "test:coverage:ci": "jest --config=jest.config.coverage.cjs --ci --maxWorkers=50%",
    "test:coverage:json": "jest --config=jest.config.coverage.cjs --coverageReporters=json-summary",
    "test:coverage:badges": "jest --config=jest.config.coverage.cjs --coverageReporters=json-summary && node scripts/generate-coverage-badges.cjs",
    "test:coverage:enforce": "node scripts/enforce-coverage-thresholds.cjs",
    "test:coverage:enforce:strict": "node scripts/enforce-coverage-thresholds.cjs --strict",
    "test:coverage:enforce:relaxed": "node scripts/enforce-coverage-thresholds.cjs --relaxed",
    "test:coverage:check": "npm run test:coverage:comprehensive && npm run test:coverage:enforce",
    "test:coverage:report": "node scripts/generate-coverage-reports.cjs",
    "test:coverage:report:quiet": "node scripts/generate-coverage-reports.cjs --quiet",
    "test:coverage:analyze": "npm run test:coverage:comprehensive && npm run test:coverage:report",
    "test:coverage:full": "npm run test:coverage:comprehensive && npm run test:coverage:report && npm run test:coverage:badges && npm run test:coverage:enforce",
    "test:coverage:exclusions": "node scripts/manage-coverage-exclusions.cjs",
    "test:coverage:exclusions:update": "node scripts/manage-coverage-exclusions.cjs --update-config",
    "test:coverage:exclusions:small": "node scripts/manage-coverage-exclusions.cjs --exclude-small-files --update-config",
    "perf:benchmark": "node scripts/performance-baseline.cjs benchmark",
    "perf:baseline": "node scripts/performance-baseline.cjs baseline",
    "perf:fast": "node scripts/performance-baseline.cjs fast",
    "perf:clean": "node scripts/performance-baseline.cjs clean",
    "perf:benchmark:quick": "node scripts/performance-benchmarks.cjs --iterations 5 --warmup 2 --quiet",
    "perf:benchmark:detailed": "node scripts/performance-benchmarks.cjs --iterations 20 --warmup 5",
    "perf:regression:analyze": "node scripts/performance-regression-detector.cjs analyze",
    "perf:regression:baseline": "node scripts/performance-regression-detector.cjs save-baseline",
    "perf:regression:cleanup": "node scripts/performance-regression-detector.cjs cleanup",
    "perf:monitor": "npm run perf:benchmark && npm run perf:regression:analyze",
    "perf:ci": "npm run perf:fast"
  },
  "dependencies": {
    "@types/diff": "^7.0.2",
    "@types/react": "^19.1.12",
    "cross-fetch": "^4.0.0",
    "diff": "^8.0.2",
    "eventsource-parser": "^1.1.2",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "ink": "^6.2.3",
    "ink-spinner": "^5.0.0",
    "keytar": "^7.9.0",
    "minimatch": "^9.0.5",
    "open": "^10.2.0",
    "picocolors": "^1.0.0",
    "prompts": "^2.4.2",
    "react": "^19.1.1",
    "yaml": "^2.8.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.13",
    "@types/prompts": "^2.4.9",
    "@types/react-test-renderer": "^19.1.0",
    "@types/yargs": "^17.0.32",
    "eslint": "^9.9.0",
    "ink-testing-library": "^4.0.0",
    "jest": "^30.1.3",
    "jest-extended": "^6.0.0",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.0.0",
    "prettier": "^3.3.2",
    "react-test-renderer": "^19.1.1",
    "simple-git": "^3.28.0",
    "ts-jest": "^29.4.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
